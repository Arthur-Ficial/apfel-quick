<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Outgoing network — connects to localhost apfel server -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Microphone access. Under Hardened Runtime (--options runtime)
         AVCaptureDevice.requestAccess(for: .audio) silently returns denied
         without this entitlement: the TCC prompt never shows and the app
         never appears in System Settings → Privacy → Microphone. Seen in
         production in v1.0.5. -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
